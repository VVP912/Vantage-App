# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Finnhub API key — get free at finnhub.io (free tier: 60 calls/min)
# Provides: insider transactions, insider sentiment MSPR, company news, news sentiment
FINNHUB_API_KEY=your_finnhub_key_here

# Google Maps API key — get free at console.cloud.google.com
# Enable: Places API, Maps JavaScript API
# Free tier: $200/month credit (covers ~40,000 place detail requests)
# Provides: real-time foot traffic / busyness scores for company locations
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Sentinel Hub (Copernicus Data Space Ecosystem) — free at dataspace.copernicus.eu
# Register at: https://dataspace.copernicus.eu/
# Then: Dashboard > User Settings > OAuth Clients > Create
# Free tier: 30,000 processing units/month (more than enough for a hackathon)
# Provides: real Sentinel-2 satellite imagery analysis of company facilities
SENTINEL_HUB_CLIENT_ID=your_sentinel_hub_client_id
SENTINEL_HUB_CLIENT_SECRET=your_sentinel_hub_client_secret

# No key needed for:
# - SEC EDGAR API (data.sec.gov) — completely free, just needs User-Agent header
# - ApeWisdom API (apewisdom.io) — completely free, no auth required
# - Yahoo Finance via yahoo-finance2 — completely free, no auth required

# On-chain prediction logging (optional but recommended for BGA bounty)
# Deploy contracts/VantagePredictionLog.sol to Polygon Amoy testnet via Remix
# (remix.ethereum.org), connect MetaMask set to Amoy (chain id 80002),
# get free test POL from https://faucet.polygon.technology/
# Then paste the deployed contract address and a throwaway wallet's
# private key (NEVER use a wallet holding real funds for this)
VANTAGE_CONTRACT_ADDRESS=
VANTAGE_WALLET_PRIVATE_KEY=
